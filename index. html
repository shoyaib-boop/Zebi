<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Special Gift For You</title>
    <style>
        :root {
            --primary-color: #ff4d6d;
            --secondary-color: #ff85a1;
            --bg-color: #fff0f3;
        }

        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        /* Background Heart Animation */
        .hearts-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 1;
        }

        .heart-particle {
            position: absolute;
            color: var(--secondary-color);
            animation: float Up 4s linear infinite;
            opacity: 0.6;
        }

        @keyframes floatUp {
            0% { transform: translateY(100vh) scale(0); opacity: 1; }
            100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
        }

        /* Main Card Container */
        .container {
            width: 90%;
            max-width: 450px;
            background: rgba(255, 255, 255, 0.9);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(255, 77, 109, 0.2);
            text-align: center;
            z-index: 10;
            backdrop-filter: blur(5px);
            border: 2px solid white;
            transition: all 0.5s ease;
        }

        .step {
            display: none;
        }

        .step.active {
            display: block;
            animation: fadeIn 0.5s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 {
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        p {
            color: #4a4a4a;
            line-height: 1.6;
        }

        /* Buttons */
        .btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 12px 28px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(255, 77, 109, 0.4);
            transition: all 0.3s ease;
            margin-top: 20px;
        }

        .btn:hover {
            background-color: #ff758f;
            transform: translateY(-2px);
        }

        /* Step 1: Gift Box Animation */
        .gift-box {
            font-size: 80px;
            cursor: pointer;
            transition: transform 0.3s ease;
            display: inline-block;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-20px); }
            60% { transform: translateY(-10px); }
        }

        .gift-box.open {
            animation: none;
            transform: scale(1.2) rotate(10deg);
        }

        /* Step 3: Secret Letter */
        .letter-text {
            text-align: left;
            background: #fff;
            padding: 20px;
            border-left: 4px solid var(--primary-color);
            border-radius: 8px;
            font-style: italic;
            max-height: 200px;
            overflow-y: auto;
            margin-top: 15px;
        }
    </style>
</head>
<body>

    <div class="hearts-bg" id="heartsBg"></div>

    <!-- Hidden Audio Player for Music -->
    <!-- Note: Replace the URL with your choice of romantic music link if needed -->
    <audio id="loveMusic" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
    </audio>

    <div class="container">
        
        <!-- STEP 1: The Gift Link/Box -->
        <div class="step active" id="step1">
            <h2>You Have Received a Gift! 🎁</h2>
            <p>Apnar jonno ekta special gift ache ekhane. Box-ti open korte niche click korun!</p>
            <div class="gift-box" id="giftIcon" onclick="openGift()">🎁</div>
            <br>
            <button class="btn" id="next1" style="display: none;" onclick="nextStep(2)">Next Step ➡️</button>
        </div>

        <!-- STEP 2: The Romantic Connection -->
        <div class="step" id="step2">
            <h2>Connecting Hearts... ❤️</h2>
            <p>Amader ei chotto transaction-ti complete korte nicher button-e chap din ar magic dekhun!</p>
            <div style="font-size: 50px; margin: 20px 0;">💖 ✨ 💖</div>
            <button class="btn" onclick="startMagic()">Unlock Secret Letter ✨</button>
        </div>

        <!-- STEP 3: The Secret Love Letter -->
        <div class="step" id="step3">
            <h2>For You, Always... 📝</h2>
            <div class="letter-text">
                Dear, <br><br>
                Tumi jokhon eta porchho, jene rakho tumi amar jiboner shobcheye sundor upohar. 
                Tomar oi mukher hashita amar protita din bhalo kore dey. Kichu kotha mukhe bola hoy na, 
                tai ei chotto chesta. Shurute background e baje jei gaan-ta, ota amar bhalobashar shur. <br><br>
                Tumi ki shara jibon evabe amar pashe thakbe? <br><br>
                <b>Always Yours, ❤️</b>
            </div>
            <div style="margin-top: 20px; font-size: 30px;">🌹 🍫 🥂</div>
        </div>

    </div>

    <script>
        // Multi-step Controller
        function nextStep(stepNumber) {
            document.querySelectorAll('.step').forEach(step => {
                step.classList.remove('active');
            });
            document.getElementById('step' + stepNumber).classList.add('active');
        }

        // Step 1: Open Gift Animation
        function openGift() {
            const gift = document.getElementById('giftIcon');
            gift.innerHTML = "🔓💝";
            gift.classList.add('open');
            document.getElementById('next1').style.display = 'inline-block';
            
            // Start heart particles effect
            setInterval(createHeart, 300);
        }

        // Step 2: Start Music & Go to Final Letter
        function startMagic() {
            const music = document.getElementById('loveMusic');
            
            // Play music (Browsers require user interaction first, which happens here)
            music.play().catch(error => {
                console.log("Audio play prevented by browser, but continuing code.");
            });

            nextStep(3);
        }

        // Heart Particles Background Animation
        function createHeart() {
            const heartsBg = document.getElementById('heartsBg');
            const heart = document.createElement('div');
            heart.classList.add('heart-particle');
            
            // Random styling for floating hearts
            heart.innerHTML = ['❤️', '💖', '💝', '💕'][Math.floor(Math.random() * 4)];
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.fontSize = Math.random() * 20 + 10 + 'px';
            heart.style.animationDuration = Math.random() * 2 + 3 + 's';
            
            heartsBg.appendChild(heart);

            // Clean up old hearts
            setTimeout(() => {
                heart.remove();
            }, 4000);
        }
    </script>
</body>
</html>
